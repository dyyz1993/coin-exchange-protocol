{
  "info": {
    "name": "金币交易协议 API",
    "description": "金币交易协议（Coin Exchange Protocol）API 完整集合\n\n文档: https://docs.coinexchange.io\n支持: support@coinexchange.io",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api-sandbox.coinexchange.io/v1",
      "description": "API 基础 URL（Sandbox 环境）"
    },
    {
      "key": "api_key",
      "value": "your-api-key",
      "description": "API Key"
    },
    {
      "key": "api_secret",
      "value": "your-api-secret",
      "description": "API Secret"
    },
    {
      "key": "timestamp",
      "value": "{{$timestamp}}",
      "description": "时间戳（毫秒）"
    }
  ],
  "auth": {
    "type": "custom",
    "auth": [
      {
        "key": "X-API-KEY",
        "value": "{{api_key}}",
        "type": "string"
      },
      {
        "key": "X-TIMESTAMP",
        "value": "{{timestamp}}",
        "type": "string"
      },
      {
        "key": "X-SIGNATURE",
        "value": "{{signature}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// 生成时间戳",
          "const timestamp = Date.now().toString();",
          "pm.environment.set('timestamp', timestamp);",
          "",
          "// 生成签名（需要 crypto-js 库）",
          "const method = pm.request.method;",
          "const path = pm.request.url.getPath();",
          "const query = pm.request.url.query.all()",
          "    .map(q => `${q.key}=${q.value}`)",
          "    .join('&');",
          "const body = pm.request.body ? pm.request.body.toString() : '';",
          "const secret = pm.environment.get('api_secret');",
          "",
          "const signString = `${method}\\n${path}\\n${query}\\n${timestamp}\\n${body}`;",
          "const signature = CryptoJS.HmacSHA256(signString, secret).toString();",
          "pm.environment.set('signature', signature);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "公共接口",
      "item": [
        {
          "name": "获取服务器时间",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/public/time",
              "host": ["{{base_url}}"],
              "path": ["public", "time"]
            },
            "description": "获取 API 服务器当前时间"
          },
          "response": [
            {
              "name": "成功响应",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"code\": 200,\n  \"message\": \"success\",\n  \"data\": {\n    \"serverTime\": 1709152093,\n    \"isoTime\": \"2026-02-28T20:28:13Z\"\n  }\n}"
            }
          ]
        },
        {
          "name": "获取交易对列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/public/symbols",
              "host": ["{{base_url}}"],
              "path": ["public", "symbols"]
            },
            "description": "获取所有可交易的交易对信息"
          }
        },
        {
          "name": "获取市场行情",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/public/ticker?symbol=BTC_USDT",
              "host": ["{{base_url}}"],
              "path": ["public", "ticker"],
              "query": [
                {
                  "key": "symbol",
                  "value": "BTC_USDT",
                  "description": "交易对（可选）"
                }
              ]
            }
          }
        },
        {
          "name": "获取订单簿",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/public/orderbook?symbol=BTC_USDT&limit=20",
              "host": ["{{base_url}}"],
              "path": ["public", "orderbook"],
              "query": [
                {
                  "key": "symbol",
                  "value": "BTC_USDT",
                  "description": "交易对（必填）"
                },
                {
                  "key": "limit",
                  "value": "20",
                  "description": "深度档位（可选，默认20）"
                }
              ]
            }
          }
        },
        {
          "name": "获取最近成交",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/public/trades?symbol=BTC_USDT&limit=50",
              "host": ["{{base_url}}"],
              "path": ["public", "trades"],
              "query": [
                {
                  "key": "symbol",
                  "value": "BTC_USDT",
                  "description": "交易对（必填）"
                },
                {
                  "key": "limit",
                  "value": "50",
                  "description": "返回条数（可选，默认50）"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "账户接口",
      "item": [
        {
          "name": "获取账户信息",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/account/info",
              "host": ["{{base_url}}"],
              "path": ["account", "info"]
            },
            "description": "获取当前账户的基本信息"
          }
        },
        {
          "name": "获取账户余额",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/account/balance",
              "host": ["{{base_url}}"],
              "path": ["account", "balance"]
            },
            "description": "查询账户中所有资产的余额"
          }
        },
        {
          "name": "获取单个资产余额",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/account/balance/BTC",
              "host": ["{{base_url}}"],
              "path": ["account", "balance", "BTC"]
            }
          }
        }
      ]
    },
    {
      "name": "交易接口",
      "item": [
        {
          "name": "创建订单",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbol\": \"BTC_USDT\",\n  \"side\": \"BUY\",\n  \"type\": \"LIMIT\",\n  \"quantity\": \"0.001\",\n  \"price\": \"40000\",\n  \"clientOrderId\": \"{{$randomUUID}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/trade/order",
              "host": ["{{base_url}}"],
              "path": ["trade", "order"]
            },
            "description": "创建一个新的订单（限价单或市价单）"
          }
        },
        {
          "name": "查询订单",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/trade/order/:orderId",
              "host": ["{{base_url}}"],
              "path": ["trade", "order", ":orderId"],
              "variable": [
                {
                  "key": "orderId",
                  "value": "123456789012345678",
                  "description": "订单ID"
                }
              ]
            }
          }
        },
        {
          "name": "取消订单",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/trade/order/:orderId",
              "host": ["{{base_url}}"],
              "path": ["trade", "order", ":orderId"],
              "variable": [
                {
                  "key": "orderId",
                  "value": "123456789012345678",
                  "description": "订单ID"
                }
              ]
            }
          }
        },
        {
          "name": "查询当前订单",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/trade/open-orders?symbol=BTC_USDT&limit=50",
              "host": ["{{base_url}}"],
              "path": ["trade", "open-orders"],
              "query": [
                {
                  "key": "symbol",
                  "value": "BTC_USDT",
                  "description": "交易对（可选）"
                },
                {
                  "key": "limit",
                  "value": "50",
                  "description": "返回条数（可选）"
                }
              ]
            }
          }
        },
        {
          "name": "查询历史订单",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/trade/history?symbol=BTC_USDT&limit=50",
              "host": ["{{base_url}}"],
              "path": ["trade", "history"],
              "query": [
                {
                  "key": "symbol",
                  "value": "BTC_USDT",
                  "description": "交易对（可选）"
                },
                {
                  "key": "startTime",
                  "value": "",
                  "description": "起始时间戳（毫秒）",
                  "disabled": true
                },
                {
                  "key": "endTime",
                  "value": "",
                  "description": "结束时间戳（毫秒）",
                  "disabled": true
                },
                {
                  "key": "limit",
                  "value": "50",
                  "description": "返回条数（可选）"
                }
              ]
            }
          }
        },
        {
          "name": "查询成交记录",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/trade/my-trades?symbol=BTC_USDT&limit=50",
              "host": ["{{base_url}}"],
              "path": ["trade", "my-trades"],
              "query": [
                {
                  "key": "symbol",
                  "value": "BTC_USDT",
                  "description": "交易对（必填）"
                },
                {
                  "key": "orderId",
                  "value": "",
                  "description": "订单ID（可选）",
                  "disabled": true
                },
                {
                  "key": "limit",
                  "value": "50",
                  "description": "返回条数（可选）"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "钱包接口",
      "item": [
        {
          "name": "获取充值地址",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/wallet/deposit/address?symbol=BTC",
              "host": ["{{base_url}}"],
              "path": ["wallet", "deposit", "address"],
              "query": [
                {
                  "key": "symbol",
                  "value": "BTC",
                  "description": "币种符号（必填）"
                },
                {
                  "key": "network",
                  "value": "",
                  "description": "网络类型（可选）",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "查询充值记录",
          "request": {
            "method": "GET",
            "header": [],
