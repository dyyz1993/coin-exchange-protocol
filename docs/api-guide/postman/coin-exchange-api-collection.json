              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbol\": \"USDT\",\n  \"network\": \"ERC20\",\n  \"address\": \"0x1234567890abcdef1234567890abcdef12345678\",\n  \"amount\": \"100\",\n  \"memo\": \"\"\n}"
